{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-set-title",
    "core:window:allow-set-fullscreen",
    "core:window:allow-close",
    "opener:default",
    "dialog:default",
    "fs:default",
    "store:default",
    {
      "identifier": "fs:default",
      "allow": [
        "**/*"
      ]
    }
  ]
}