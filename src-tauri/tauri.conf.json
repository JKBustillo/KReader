{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KReader",
  "version": "0.2.2",
  "identifier": "com.kreader.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "KReader",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
      "capabilities": []
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Karmine",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/512x512.png",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "cbz"
        ],
        "mimeType": "application/x-cbz",
        "name": "Comic Book Zip",
        "description": "KReader CBZ Comic",
        "role": "Editor"
      }
    ]
  }
}